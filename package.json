{\n  \"name\": \"snakelle\",\n  \"version\": \"0.1.0\",\n  \"description\": \"Web-based, canvas-driven daily one-shot game inspired by Snake\",\n  \"private\": true,\n  \"type\": \"module\",\n  \"engines\": {\n    \"node\": \">=20.0.0\"\n  },\n  \"packageManager\": \"pnpm@9.0.0\",\n  \"scripts\": {\n    \"dev\": \"pnpm -r --parallel --filter ./apps/web run dev\",\n    \"build\": \"pnpm -r --filter \"./packages/**\" run build && pnpm -r --filter ./apps/web run build\",\n    \"lint\": \"pnpm -r run lint\",\n    \"type-check\": \"pnpm -r run type-check\",\n    \"test\": \"pnpm -r --filter ./packages/game-core run test\",\n    \"format\": \"prettier --write .\"\n  },\n  \"devDependencies\": {\n    \"@typescript-eslint/eslint-plugin\": \"^7.0.0\",\n    \"@typescript-eslint/parser\": \"^7.0.0\",\n    \"eslint\": \"^8.56.0\",\n    \"prettier\": \"^3.1.0\",\n    \"typescript\": \"^5.3.3\"\n  }\n}