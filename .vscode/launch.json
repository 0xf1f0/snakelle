{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Web App (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/apps/web",
      "sourceMaps": true,
      "preLaunchTask": "dev-server",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Web App (Edge)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/apps/web",
      "sourceMaps": true,
      "preLaunchTask": "dev-server",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Attach to Web App (Chrome)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/apps/web",
      "sourceMaps": true
    },
    {
      "name": "Attach to Web App (Edge)",
      "type": "msedge",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/apps/web",
      "sourceMaps": true
    },
    {
      "name": "Debug Tests (game-core)",
      "type": "node",
      "request": "launch",
      "name": "Debug Vitest Tests",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "--filter",
        "@snakelle/game-core",
        "run",
        "test:watch"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "NODE_ENV": "test"
      }
    },
    {
      "name": "Debug Current Test File",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "exec",
        "vitest",
        "run",
        "${relativeFile}"
      ],
      "cwd": "${workspaceFolder}/packages/game-core",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ],
  "compounds": []
}
